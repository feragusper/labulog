# Local dev defaults to sqlite. For Postgres set a full URL, e.g.
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/laburolog
DATABASE_URL=sqlite:///laburolog.db

# CHANGE in production. Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-me

# Minutes a login token stays valid
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated origins allowed by CORS (dev front). Empty = same-origin only.
CORS_ORIGINS=http://localhost:5173
